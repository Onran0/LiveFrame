@animation name "anim1" {
    @keyframe time 0 {
        @scope rotation-interp "squad" {
            @bone name "head" {
                @rotation value (0, 0, 0)
            }
        }
    }

    @keyframe time 1 {
        @scope rotation-interp "squad" {
            @bone name "head" {
                @rotation value (0, 0, 35)
            }
        }
    }

    @keyframe time 2 {
        @scope rotation-interp "squad" {
            @bone name "head" {
                @rotation value (0, 0, 0)
            }
        }
    }
}
