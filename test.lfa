@animation name "anim1" loop true {
    @keyframe time 0 {
        @scope rotation-interp "squad" {
            @bone name "head" {
                @rotation value (0, 0, 35)
            }

            @bone name "left_arm" {
                @rotation value (60, 0, 0)
            }

            @bone name "right_arm" {
                @rotation value (-60, 0, 0)
            }
        }
    }

    @keyframe time 2 {
        @scope rotation-interp "squad" {
            @bone name "head" {
                @rotation value (0, 0, -35)
            }

            @bone name "left_arm" {
                @rotation value (-60, 0, 0)
            }

            @bone name "right_arm" {
                @rotation value (60, 0, 0)
            }
        }
    }
}
