@animation name "test" {
    @keyframe time 0 {
        @scope rotation-interp "squad" {
            @bone name "spine" {
                @rotation value (0, 0, 0)
            }

            @bone name "head" {
                @rotation value (0, 0, 0)
            }
        }
    }

    @keyframe time 1 {
        @scope rotation-interp "squad" {
            @bone name "spine" {
                @rotation value (0, 90, 0)
            }

            @bone name "head" {
                @rotation value (0, 0, 90)
            }
        }
    }
}